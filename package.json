{
  "name": "vultisig-windows",
  "packageManager": "yarn@4.15.0",
  "workspaces": [
    "./**",
    "!vendor/**"
  ],
  "scripts": {
    "lint": "eslint --cache --cache-location node_modules/.cache/eslint/ 'clients/desktop/src/**/*.{js,jsx,ts,tsx}' 'clients/extension/src/**/*.{js,jsx,ts,tsx}' 'clients/desktop/vite.config.mts' 'clients/extension/vite.config.ts' 'core/**/*.{js,jsx,ts,tsx}' 'lib/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint --cache --cache-location node_modules/.cache/eslint/ 'clients/desktop/src/**/*.{js,jsx,ts,tsx}' 'clients/extension/src/**/*.{js,jsx,ts,tsx}' 'clients/desktop/vite.config.mts' 'clients/extension/vite.config.ts' 'core/**/*.{js,jsx,ts,tsx}' 'lib/**/*.{js,jsx,ts,tsx}' --fix",
    "dev:desktop": "wails dev -s -skipbindings -m -nosyncgomod",
    "dev:desktop:full": "wails dev",
    "build:desktop": "NODE_OPTIONS=--max-old-space-size=8192 yarn workspace @clients/desktop build",
    "build:extension": "yarn workspace @clients/extension build",
    "build:extension:firefox": "yarn workspace @clients/extension build:firefox",
    "dev:extension": "yarn workspace @clients/extension dev",
    "build": "NODE_OPTIONS=--max-old-space-size=8192 yarn workspace @clients/desktop build",
    "typecheck": "tsgo --noEmit",
    "test": "vitest run",
    "knip": "knip",
    "check:all": "yarn lint && yarn typecheck && yarn test && yarn workspace @clients/extension test && yarn workspace @clients/desktop test:ci && yarn knip",
    "knip:fix": "knip --fix --allow-remove-files",
    "check": "concurrently --kill-others-on-fail \"yarn typecheck\" \"yarn lint:fix\" && yarn knip",
    "translate": "yarn workspace @core/ui translate",
    "update": "yarn set version latest && yarn dlx npm-check-updates@latest -u --workspaces --root && yarn install"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@google-cloud/translate": "^9.4.1",
    "@types/chrome": "^0.1.42",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@typescript/native-preview": "7.0.0-dev.20260316.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-storybook": "^10.4.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "knip": "^6.14.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.7"
  },
  "resolutions": {
    "@trustwallet/wallet-core": "4.6.9",
    "viem": "npm:2.47.4",
    "@noble/hashes": "1.8.0",
    "@vultisig/mpc-types": "0.2.3",
    "@vultisig/mpc-wasm": "0.1.5",
    "tar": ">=7.5.11",
    "minimatch@^3.1.2": ">=3.1.3",
    "minimatch@^9.0.0": ">=9.0.7",
    "minimatch@^9.0.4": ">=9.0.7",
    "minimatch@^9.0.5": ">=9.0.7",
    "minimatch@^10.1.1": ">=10.2.3",
    "@isaacs/brace-expansion": ">=5.0.1",
    "esbuild": "0.27.4"
  },
  "dependencies": {
    "@noble/curves": "^2.2.0",
    "lottie-react": "^2.4.1",
    "react-markdown": "^10.1.0"
  }
}
