{
  "name": "@clients/desktop",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{js,jsx,ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,js,jsx,json,css,scss,md}'",
    "format:wails": "prettier --write 'wailsjs/**/*.{ts,js}'",
    "dev": "vite",
    "build": "node --max-old-space-size=8192 ../../node_modules/typescript/bin/tsc && node --max-old-space-size=8192 ../../node_modules/vite/bin/vite.js build",
    "preview": "vite preview",
    "test": "vitest --config vitest.config.mts",
    "test:ci": "vitest run --config vitest.config.mts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vite-plugin-circular-dependency": "^0.6.0",
    "vite-plugin-static-copy": "3.3.0",
    "vitest": "4.1.0"
  },
  "dependencies": {
    "@core/ui": "workspace:^",
    "@lib/ui": "workspace:^",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "@vultisig/core-chain": "2.17.0",
    "@vultisig/core-config": "0.9.1",
    "@vultisig/core-mpc": "1.7.0",
    "@vultisig/lib-utils": "0.10.1",
    "@vultisig/sdk": "2.4.0",
    "@wailsapp/runtime": "workspace:^",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-i18next": "^16.5.8",
    "styled-components": "6.3.11"
  }
}
