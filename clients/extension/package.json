{
  "name": "@clients/extension",
  "private": true,
  "version": "0.2.1",
  "description": "Vultisig Extension integrates Vultisig into web applications, enabling users to securely sign blockchain transactions.",
  "author": {
    "name": "Vultisig",
    "email": "info@vultisig.com",
    "url": "https://vultisig.com"
  },
  "type": "module",
  "scripts": {
    "build:app": "tsc -b && vite build",
    "build:background": "tsc -b && cross-env CHUNK=background vite build",
    "build:content": "tsc -b && cross-env CHUNK=content vite build",
    "build:inpage": "tsc -b && cross-env CHUNK=inpage vite build",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 npm-run-all --serial build:app build:background build:content build:inpage",
    "build:firefox": "node scripts/clean-dist.mjs && cross-env NODE_OPTIONS=--max-old-space-size=8192 VULTISIG_EXTENSION_TARGET=firefox yarn build && node scripts/prepare-firefox-build.mjs",
    "dev": "node watch.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config tests/unit/vitest.config.ts",
    "test:unit": "vitest run --config tests/unit/vitest.config.ts",
    "test:unit:watch": "vitest --config tests/unit/vitest.config.ts",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:all": "yarn test:unit && yarn test:integration",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts"
  },
  "dependencies": {
    "@core/extension": "workspace:^",
    "@core/inpage-provider": "workspace:^",
    "@cosmjs/amino": "^0.38.1",
    "@cosmjs/cosmwasm-stargate": "^0.38.1",
    "@cosmjs/proto-signing": "^0.38.1",
    "@cosmjs/stargate": "^0.38.1",
    "@hookform/resolvers": "^5.2.2",
    "@keplr-wallet/provider": "^0.13.34",
    "@lib/extension": "workspace:^",
    "@solana/wallet-standard-features": "^1.3.0",
    "@tanstack/react-query": "^5.100.11",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.2.4",
    "@tonconnect/protocol": "^2.4.0",
    "@vultisig/core-chain": "2.0.0",
    "@vultisig/core-mpc": "1.2.13",
    "@vultisig/lib-utils": "0.10.1",
    "@vultisig/sdk": "0.24.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "bech32": "^2.0.0",
    "bitcoinjs-lib": "^7.0.1",
    "bs58": "^6.0.0",
    "cosmjs-types": "^0.11.0",
    "ethers": "^6.16.0",
    "i18next": "^26.2.0",
    "long": "^5.3.2",
    "mipd": "^0.0.7",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "react-i18next": "^17.0.8",
    "styled-components": "^6.4.2",
    "tronweb": "^6.3.0",
    "uuid": "^14.0.0",
    "viem": "^2.50.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@core/ui": "workspace:^",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.9",
    "@keplr-wallet/types": "^0.13.34",
    "@lib/ui": "workspace:^",
    "@playwright/test": "^1.60.0",
    "@solana/web3.js": "^1.98.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trustwallet/wallet-core": "^4.6.9",
    "@types/chrome": "^0.1.42",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3",
    "@types/ws": "^8",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.2",
    "express": "^5.2.1",
    "happy-dom": "^20.9.0",
    "npm-run-all2": "^9.0.0",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vite-plugin-node-polyfills": "^0.28.0",
    "vite-plugin-static-copy": "^4.1.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.7",
    "web-push": "^3.6.7",
    "ws": "^8.20.1"
  }
}
