{
  "name": "@clients/extension",
  "private": true,
  "version": "0.2.1",
  "description": "Vultisig Extension integrates Vultisig into web applications, enabling users to securely sign blockchain transactions.",
  "author": {
    "name": "Vultisig",
    "email": "info@vultisig.com",
    "url": "https://vultisig.com"
  },
  "type": "module",
  "scripts": {
    "build:app": "tsc -b && vite build",
    "build:background": "tsc -b && cross-env CHUNK=background vite build",
    "build:content": "tsc -b && cross-env CHUNK=content vite build",
    "build:inpage": "tsc -b && cross-env CHUNK=inpage vite build",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 npm-run-all --serial build:app build:background build:content build:inpage && node scripts/assert-extension-brand.mjs vultisig",
    "build:station": "node scripts/clean-dist.mjs && cross-env NODE_OPTIONS=--max-old-space-size=8192 VULTISIG_EXTENSION_BRAND=station npm-run-all --serial build:app build:background build:content build:inpage && node scripts/qa-extension-brand.mjs station --skip-browser",
    "build:firefox": "node scripts/clean-dist.mjs && cross-env NODE_OPTIONS=--max-old-space-size=8192 VULTISIG_EXTENSION_TARGET=firefox yarn build && node scripts/prepare-firefox-build.mjs",
    "dev": "node watch.js",
    "lint": "yarn lint:src && yarn lint:scripts",
    "lint:src": "eslint --cache --cache-location node_modules/.cache/eslint/ 'src/**/*.{js,jsx,ts,tsx}' vite.config.ts",
    "lint:scripts": "eslint --cache --cache-location node_modules/.cache/eslint/ 'scripts/*.{js,mjs,cjs,ts}' watch.js",
    "lint:tests": "eslint 'tests/**/*.{js,jsx,ts,tsx}'",
    "lint:all": "eslint .",
    "preview": "vite preview",
    "qa:brand": "node scripts/qa-extension-brand.mjs vultisig",
    "qa:brand:station": "node scripts/qa-extension-brand.mjs station",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config tests/unit/vitest.config.ts",
    "test:unit": "vitest run --config tests/unit/vitest.config.ts",
    "test:unit:watch": "vitest --config tests/unit/vitest.config.ts",
    "test:integration": "vitest run --config tests/integration/vitest.config.ts",
    "test:all": "yarn test:unit && yarn test:integration",
    "test:e2e": "playwright test --config tests/e2e/playwright.config.ts"
  },
  "dependencies": {
    "@core/extension": "workspace:^",
    "@core/inpage-provider": "workspace:^",
    "@cosmjs/amino": "^0.39.0",
    "@cosmjs/cosmwasm-stargate": "^0.39.0",
    "@cosmjs/crypto": "^0.39.0",
    "@cosmjs/encoding": "^0.39.0",
    "@cosmjs/proto-signing": "^0.39.0",
    "@cosmjs/stargate": "^0.39.0",
    "@hookform/resolvers": "^5.4.0",
    "@keplr-wallet/provider": "^0.13.38",
    "@lib/extension": "workspace:^",
    "@solana/wallet-standard-features": "^1.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@ton/core": "^0.63.1",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^16.3.0",
    "@tonconnect/protocol": "^2.4.0",
    "@vultisig/core-chain": "2.22.2",
    "@vultisig/core-mpc": "1.8.16",
    "@vultisig/lib-utils": "0.10.4",
    "@vultisig/sdk": "2.13.2",
    "@wallet-standard/base": "^1.1.1",
    "@wallet-standard/features": "^1.1.1",
    "bech32": "^2.0.0",
    "bitcoinjs-lib": "^7.0.1",
    "bs58": "^6.0.0",
    "cosmjs-types": "^0.11.0",
    "ethers": "^6.16.0",
    "i18next": "^25.8.18",
    "long": "^5.3.2",
    "mipd": "^0.0.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.78.0",
    "react-i18next": "^16.5.8",
    "styled-components": "6.3.11",
    "tronweb": "^6.3.0",
    "uuid": "^13.0.0",
    "viem": "^2.47.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@core/ui": "workspace:^",
    "@fontsource/montserrat": "^5.2.8",
    "@fontsource/roboto-mono": "^5.2.9",
    "@keplr-wallet/types": "^0.13.38",
    "@lib/ui": "workspace:^",
    "@playwright/test": "^1.60.0",
    "@solana/web3.js": "^1.98.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@trustwallet/wallet-core": "^4.7.0",
    "@types/chrome": "^0.1.43",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/web-push": "^3",
    "@types/ws": "^8",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.2",
    "express": "^5.2.1",
    "happy-dom": "^20.10.2",
    "npm-run-all2": "^7.0.2",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vite-plugin-node-polyfills": "0.25.0",
    "vite-plugin-static-copy": "3.3.0",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "3.6.0",
    "vitest": "4.1.0",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  }
}
