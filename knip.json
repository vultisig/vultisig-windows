{
  "ignore": [
    "clients/desktop/wailsjs/**",
    "core/ui/transaction-history/**",
    "lib/ui/form/FormCheckBadge.tsx"
  ],
  "ignoreBinaries": [
    "go",
    "wails"
  ],
  "ignoreDependencies": [
    "@secretlint/secretlint-rule-preset-recommend",
    "@vitest/coverage-v8",
    "babel-plugin-react-compiler",
    "markdown-link-check"
  ],
  "ignoreIssues": {
    "clients/extension/package.json": [
      "devDependencies"
    ],
    "core/ui/i18n/scripts/check-integrity.ts": [
      "files"
    ],
    "core/ui/i18n/scripts/check-unused.ts": [
      "files"
    ],
    "core/ui/i18n/scripts/find-duplicates.ts": [
      "files"
    ],
    "core/ui/i18n/scripts/review-quality.ts": [
      "files"
    ],
    "core/ui/i18n/scripts/translate.ts": [
      "files"
    ],
    "core/ui/i18n/utils/i18nGlossary.ts": [
      "exports"
    ],
    "core/ui/i18n/utils/i18nSyntax.ts": [
      "exports"
    ],
    "core/ui/i18n/utils/translateTexts.ts": [
      "files"
    ],
    "core/ui/package.json": [
      "dependencies"
    ],
    "core/ui/scripts/validatePublic.ts": [
      "files"
    ],
    "lib/codegen/package.json": [
      "dependencies"
    ],
    "lib/codegen/utils/createFile.ts": [
      "files"
    ],
    "lib/codegen/utils/createTsFile.ts": [
      "files"
    ],
    "lib/codegen/utils/formatCode.ts": [
      "files"
    ],
    "package.json": [
      "devDependencies"
    ],
    "scripts/quality-audit.mjs": [
      "files"
    ]
  },
  "workspaces": {
    "clients/desktop": {
      "entry": [
        "scripts/dev-desktop.mjs"
      ],
      "project": [
        "**/*.{ts,tsx}",
        "scripts/**/*.{js,mjs}"
      ]
    },
    "clients/extension": {
      "entry": [
        "src/background/index.ts",
        "src/background/firefox.ts",
        "src/content/index.ts",
        "src/inpage/index.ts",
        "src/pages/popup.tsx",
        "tests/unit/**/*.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "tests/unit/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "@types/chrome",
        "@fontsource/montserrat",
        "@fontsource/roboto-mono",
        "@testing-library/jest-dom",
        "@types/express",
        "@types/web-push",
        "express",
        "web-push"
      ]
    },
    "core/inpage-provider": {
      "project": [
        "**/*.{ts,tsx}"
      ]
    },
    "core/extension": {
      "project": [
        "**/*.{ts,tsx}"
      ]
    },
    "lib/extension": {
      "project": [
        "**/*.{ts,tsx,js}"
      ]
    },
    "core/ui": {
      "entry": [
        "vite/plugins.ts",
        "vite/staticCopy.ts"
      ],
      "project": [
        "**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "vite-plugin-static-copy"
      ]
    },
    "lib/ui": {
      "project": [
        "**/*.{ts,tsx}"
      ]
    }
  }
}
