{
  "ignore": [
    "clients/desktop/wailsjs/**",
    "core/ui/transaction-history/**",
    "lib/ui/form/FormCheckBadge.tsx",
    "core/ui/qbtc/claim/hooks/useQbtcClaimSignMutation.ts"
  ],
  "ignoreBinaries": [
    "wails"
  ],
  "ignoreDependencies": [
    "babel-plugin-react-compiler"
  ],
  "workspaces": {
    ".": {
      "ignoreDependencies": [
        "@vultisig/mpc-types",
        "@vultisig/mpc-wasm"
      ]
    },
    "clients/desktop": {
      "project": [
        "**/*.{ts,tsx}"
      ]
    },
    "clients/extension": {
      "entry": [
        "src/background/index.ts",
        "src/content/index.ts",
        "src/inpage/index.ts",
        "src/pages/popup.tsx",
        "tests/unit/**/*.{ts,tsx}"
      ],
      "project": [
        "src/**/*.{ts,tsx}",
        "tests/unit/**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "@types/chrome",
        "@fontsource/montserrat",
        "@fontsource/roboto-mono",
        "@testing-library/jest-dom",
        "@testing-library/react",
        "@types/express",
        "@types/web-push",
        "express",
        "web-push"
      ]
    },
    "core/inpage-provider": {
      "project": [
        "**/*.{ts,tsx}"
      ]
    },
    "core/extension": {
      "project": [
        "**/*.{ts,tsx}"
      ]
    },
    "lib/extension": {
      "project": [
        "**/*.{ts,tsx,js}"
      ]
    },
    "core/ui": {
      "entry": [
        "vite/plugins.ts",
        "vite/staticCopy.ts",
        "mpc/bootstrapMpcEngine.ts"
      ],
      "project": [
        "**/*.{ts,tsx}"
      ],
      "ignoreDependencies": [
        "vite-plugin-static-copy"
      ]
    },
    "lib/ui": {
      "project": [
        "**/*.{ts,tsx}"
      ]
    }
  }
}